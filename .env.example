# Frontend (Vite / Netlify)
VITE_AI_PROVIDER=demo
VITE_AUTH_API_URL=http://localhost:4000
# Production misol:
# VITE_AUTH_API_URL=https://your-backend.onrender.com

# IMPORTANT: VITE_* qiymatlar brauzerga ochiq bo'ladi.
# Productionda maxfiy API keylarni VITE_* orqali bermang.
# VITE_GEMINI_API_KEY=your_gemini_key
# VITE_GEMINI_MODEL=gemini-2.5-flash
# VITE_OPENAI_API_KEY=your_openai_key
# VITE_OPENAI_MODEL=gpt-4o-mini

# Backend (Node / Render, Railway, Fly)
# AUTH_PORT=4000
# AUTH_TOKEN_SECRET=change-this-secret-in-production
# AUTH_TOKEN_TTL_SECONDS=604800
# AUTH_CORS_ORIGIN=http://localhost:5173
# Production misol:
# AUTH_CORS_ORIGIN=https://your-site.netlify.app,https://your-custom-domain.com
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DATABASE_SSL=true
# DATABASE_AUTO_CREATE=true
# MIGRATE_FILE_DATA=true
